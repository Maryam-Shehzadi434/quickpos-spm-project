{
    "name": "astercafe/landing-page",
    "description": "Aster Café - Midnight Coffee & Silent Stories Landing Page with CI/CD Pipeline",
    "type": "project",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "scripts": {
        "test": "vendor/bin/phpunit --testdox",
        "test:verbose": "vendor/bin/phpunit --testdox --verbose",
        "analyse": "vendor/bin/phpstan analyse --level=5",
        "check": [
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}